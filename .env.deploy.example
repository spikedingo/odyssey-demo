# Cloudflare deployment credentials (do not commit real values)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# Production database (Neon or other Postgres)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Frontend build-time API URL
EXPO_PUBLIC_API_BASE_URL=https://odyssey-backend-prod.your-subdomain.workers.dev
