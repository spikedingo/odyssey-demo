{
  "expo": {
    "name": "Odyssey",
    "slug": "odyssey-dashboard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "odyssey",
    "ios": {
      "bundleIdentifier": "com.odyssey.dashboard",
      "supportsTablet": true
    },
    "android": {
      "package": "com.odyssey.dashboard",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#faf9f7"
      }
    },
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf9f7"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-router", { "root": "./src/app" }],
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/"
    }
  }
}
