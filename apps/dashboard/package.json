{
  "name": "dashboard",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "dev:web": "expo start --web",
    "dev:ios": "expo start --ios",
    "dev:android": "expo start --android",
    "build": "expo export --platform web",
    "export": "expo export --platform web --output-dir dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:responsive": "playwright test e2e/responsive.spec.ts"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.0",
    "@expo-google-fonts/inter": "^0.2.3",
    "@odyssey/api-client": "workspace:*",
    "@odyssey/shared": "workspace:*",
    "@odyssey/types": "workspace:*",
    "@odyssey/ui": "workspace:*",
    "@react-native/assets-registry": "0.74.87",
    "@tanstack/react-query": "^5.62.8",
    "expo": "~51.0.39",
    "expo-constants": "~16.0.2",
    "expo-font": "~12.0.10",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.23",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "lucide-react-native": "^0.468.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.2.79",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.4",
    "react-test-renderer": "18.2.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.2"
  }
}
